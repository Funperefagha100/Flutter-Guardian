{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "Captured user details from Google OAuth",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Unique user ID" },
        "displayName": { "type": "string", "description": "User's full name" },
        "email": { "type": "string", "format": "email", "description": "User's email" },
        "photoURL": { "type": "string", "description": "URL to user's profile picture" },
        "lastLogin": { "type": "string", "format": "date-time", "description": "Timestamp of last login" }
      },
      "required": ["uid", "email"]
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": "User",
      "description": "Collection of user profiles"
    }
  }
}
