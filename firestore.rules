rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helper Functions ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // Tiered Identity Logic: We don't have admins yet, so just owner.
    
    // --- User Profile Security ---
    match /users/{userId} {
      // Identity Poisoning Guard
      allow get: if isOwner(userId) && isValidId(userId);
      
      // Secure List Queries
      allow list: if isSignedIn() && resource.data.uid == request.auth.uid;

      function isValidUser(data) {
        return data.keys().hasAll(['uid', 'email']) &&
               data.uid is string && data.uid.size() <= 128 &&
               data.email is string && data.email.size() <= 256 &&
               // Enforce UID matches auth UID
               data.uid == request.auth.uid &&
               // Optional fields
               (!data.keys().contains('displayName') || (data.displayName is string && data.displayName.size() <= 128)) &&
               (!data.keys().contains('photoURL') || (data.photoURL is string && data.photoURL.size() <= 1024)) &&
               (!data.keys().contains('lastLogin') || data.lastLogin == request.time);
      }

      allow create: if isOwner(userId) && isValidUser(incoming()) && isValidId(userId);
      
      allow update: if isOwner(userId) && isValidUser(incoming()) && (
        // Action: Profile Update (Immutable sensitive fields like uid/email could be added here)
        incoming().uid == existing().uid &&
        incoming().email == existing().email &&
        incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'photoURL', 'lastLogin'])
      );
      
      allow delete: if false; // Users shouldn't delete their accounts directly from client normally
    }
  }
}
